# Atlas — environment variables (example)
# Copy this file to `.env` and fill in real values. NEVER commit .env.

# -----------------------------------------------------------------------------
# Hard data gate
# -----------------------------------------------------------------------------
# false = dummy/seed data only; the LLM call refuses to send any prompt
# containing what looks like real email addresses.
# true  = allow real data to flow.
ENTERPRISE_MODE=false

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://atlas:atlas_dev_only@localhost:5432/atlas

# -----------------------------------------------------------------------------
# LLM provider (Gemini default, Anthropic alternative)
# -----------------------------------------------------------------------------
LLM_PROVIDER=gemini
LLM_MODEL=gemini-1.5-pro

# Set the credential for whichever provider is active.
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Google OAuth (sign-in)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/callback

# -----------------------------------------------------------------------------
# JWT signing
# -----------------------------------------------------------------------------
JWT_SECRET=change-me-to-a-long-random-string

# -----------------------------------------------------------------------------
# Access control
# -----------------------------------------------------------------------------
ALLOWED_EMAILS=demo@example.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# -----------------------------------------------------------------------------
# Token encryption (Fernet) — encrypts Google OAuth tokens at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave blank in dev for plaintext fallback (local-only).
# -----------------------------------------------------------------------------
TOKEN_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Voice (Google Cloud Speech for STT, ElevenLabs for TTS)
# -----------------------------------------------------------------------------
VOICE_ENABLED=false
STT_REGION=us-central1
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_SPEED=0.9
ELEVENLABS_STABILITY=0.5
ELEVENLABS_SIMILARITY_BOOST=0.75
ELEVENLABS_STYLE=0.0
